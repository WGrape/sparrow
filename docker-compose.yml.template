# ======================================================= #
# During the Sparrow startup process, a docker-compose.y- #
# ml file is automatically generated in the root directo- #
# ry. This file is simply an environment variable templa- #
# te and has no actual function.                          #
# ======================================================= #
# 在sparrow启动过程中, 会自动在根目录下生成一个.env文件, 所以此  #
# 文件也只是一个环境变量模板的文件, 无任何实际性作用             #
# ======================================================= #
#                                                         #
#               docker-compose.yml.template               #
#                                                         #
###########################################################
###################### General Setup ######################
###########################################################

version: '3'

networks:
  backend:
    driver: ${NETWORKS_DRIVER}

services:

  ### ZOOKEEPER ##################################################
  zookeeper:
    hostname: zookeeper
    image: sparrow-app-zookeeper:${IMAGE_APP_ZOOKEEPER_VERSION} # pull_or_build_app_image(local image=>remote image=>build image)
    container_name: sparrow_container_${CONTAINER_NAMESPACE}_zookeeper
    platform: ${FROM_PLATFORM}
    restart: always
    environment:
      TZ: ${TZ}
      LANG: C.UTF-8
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./zookeeper/:/home/sparrow/zookeeper/
      - ./zookeeper/data/:/opt/zookeeper-${IMAGE_OFFICIAL_ZOOKEEPER_VERSION}/data/ # data persistence
    ports:
      # You don't need to expose the port in the Dockerfile.
      - "${ZOOKEEPER_HOST_PORT}:${ZOOKEEPER_CONTAINER_PORT}"
    networks:
      - backend
    # only for debug
    # command: "tail -f /dev/null"

  ### Go #########################################################
  go:
    hostname: go
    image: sparrow-app-go:${IMAGE_APP_GO_VERSION} # pull_or_build_app_image(local image=>remote image=>build image)
    container_name: sparrow_container_${CONTAINER_NAMESPACE}_go
    platform: ${FROM_PLATFORM}
    restart: always
    environment:
      TZ: ${TZ}
      LANG: C.UTF-8
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./go/:/home/sparrow/go/
      - ./go/data/:/var/data/go/ # data persistence, use a common data persistence directory /var/data/{SERVICE}
      - ${GO_PATH}:/go
    extra_hosts:
      - "dockerhost:${DOCKER_HOST_IP}"
      - "host.docker.internal:${DOCKER_HOST_IP}"
    ports:
      # You don't need to expose the port in the Dockerfile.
      - "${GO_HOST_PORT}:${GO_CONTAINER_PORT}"
    tty: true
    networks:
      - backend
    # only for debug
    # command: "tail -f /dev/null"

  ### PHPFPM #####################################################
  phpfpm:
    hostname: phpfpm
    image: sparrow-app-phpfpm:${IMAGE_APP_PHPFPM_VERSION} # pull_or_build_app_image(local image=>remote image=>build image)
    container_name: sparrow_container_${CONTAINER_NAMESPACE}_phpfpm
    platform: ${FROM_PLATFORM}
    restart: always
    environment:
      TZ: ${TZ}
      LANG: C.UTF-8
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./phpfpm/:/home/sparrow/phpfpm/
      - ./phpfpm/data/:/var/data/phpfpm/ # data persistence, use a common data persistence directory /var/data/{SERVICE}
      - ${PHPFPM_LOCALHOST_LARAVEL_APP_LOG_PATH}:${PHPFPM_LARAVEL_APP_LOG_PATH}
    extra_hosts:
      - "dockerhost:${DOCKER_HOST_IP}"
      - "host.docker.internal:${DOCKER_HOST_IP}"
    ports:
      # You don't need to expose the port in the Dockerfile.
      - "${PHPFPM_HOST_PORT}:${PHPFPM_CONTAINER_PORT}"
      - "${PHPFPM_HOST_XDEBUG_PORT}:${PHPFPM_CONTAINER_XDEBUG_PORT}"
    networks:
      - backend
    # only for debug
    # command: "tail -f /dev/null"

  ### PYTHON #####################################################

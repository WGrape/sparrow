      - "${NGINX_HOST_GO_PROXY_PORT}:${NGINX_CONTAINER_GO_PROXY_PORT}"
      - "${NGINX_HOST_PHPFPM_PROXY_PORT}:${NGINX_CONTAINER_PHPFPM_PROXY_PORT}"

      - ${NGINX_SITES_PATH}:/etc/nginx/sites-available/
    ports:
      # You don't need to expose the port in the Dockerfile.
      - "${NGINX_HOST_HTTP_PORT}:${NGINX_CONTAINER_HTTP_PORT}"

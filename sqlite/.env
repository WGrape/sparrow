### SQLITE #################################################

# -------------- image config ---------------
# official image
IMAGE_OFFICIAL_SQLITE_NAME=python
IMAGE_OFFICIAL_SQLITE_VERSION=3.11-slim
# basic image
IMAGE_BASIC_SQLITE_VERSION=3.11
# app image
IMAGE_APP_SQLITE_VERSION=latest
# -------------- service config --------------
SQLITE_HOST_PORT=4600
SQLITE_CONTAINER_PORT=8080
SQLITE_DATA_DIR=/var/data/sqlite
SQLITE_DB_FILE=sparrow.db

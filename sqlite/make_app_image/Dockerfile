ARG FROM_PLATFORM
ARG IMAGE_BASIC_SQLITE_VERSION
FROM --platform=${FROM_PLATFORM} sparrow-basic-sqlite:${IMAGE_BASIC_SQLITE_VERSION}

ARG SQLITE_DATA_DIR
ARG SQLITE_DB_FILE
ARG SQLITE_CONTAINER_PORT

ENV SQLITE_DATA_DIR=${SQLITE_DATA_DIR}
ENV SQLITE_DB_FILE=${SQLITE_DB_FILE}
ENV SQLITE_CONTAINER_PORT=${SQLITE_CONTAINER_PORT}

RUN mkdir -p ${SQLITE_DATA_DIR}

EXPOSE ${SQLITE_CONTAINER_PORT}

CMD sh -c "sqlite_web --host 0.0.0.0 --port ${SQLITE_CONTAINER_PORT} --no-browser ${SQLITE_DATA_DIR}/${SQLITE_DB_FILE}"
